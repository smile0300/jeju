# 제주 여행 도우미 - .gitignore

# 1. 백업 및 복구 파일 (민감 정보 포함 가능성)
*_recovered.js
*~
*.bak
*.tmp

# 2. 로컬 개발 환경 제어
.DS_Store
Thumbs.db

# 3. 환경 변수 (배포 시 Worker Secret 권장)
.env
secret.json

# 4. 의존성 및 용량 최적화
node_modules/
package-lock.json

# 5. 디버그 및 임시 스크립트 (자동화 작업 중 생성됨)
debug_*
inspect_page.js
test_api.py
execution/debug_crawl.png
*.webp
*.png